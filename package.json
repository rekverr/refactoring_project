{
  "name": "library-refactoring-architecture",
  "version": "1.0.0",
  "description": "Refactoring architecture project: in-memory library system with SOLID, Strategy, Observer, tests, coverage and CI artifacts.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "jest",
    "test:coverage": "jest --coverage --ci --reporters=default --reporters=jest-junit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "architecture",
    "refactoring",
    "solid",
    "sonarqube",
    "jest"
  ],
  "author": "Viktor Shegelsky",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/jest": "^29.5.12",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "jest-junit": "^17.0.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "jest-junit": {
    "outputDirectory": "reports/junit",
    "outputName": "junit.xml"
  }
}
